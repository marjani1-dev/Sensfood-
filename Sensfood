 *{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,system-ui,sans-serif;}
body{background:#f7f7f7;color:#111;}
.app{max-width:480px;margin:0 auto;min-height:100vh;background:#fff;position:relative;}
.header{position:sticky;top:0;z-index:10;background:#fff;border-bottom:1px solid #eee;padding:8px 12px;}
.top-location{font-size:12px;color:#666;display:flex;gap:4px;align-items:center;}
.top-title{font-size:18px;font-weight:700;margin-top:4px;}
.search-bar{margin-top:8px;background:#f1f1f1;border-radius:999px;padding:8px 12px;font-size:13px;color:#777;display:flex;gap:6px;align-items:center;}
.role-tabs{margin-top:8px;display:flex;border-radius:999px;background:#f1f1f1;padding:3px;}
.role-tabs button{flex:1;border:none;background:transparent;padding:6px 0;border-radius:999px;font-size:12px;cursor:pointer;}
.role-tabs button.active{background:#000;color:#fff;font-weight:600;}
.header-title{font-size:16px;font-weight:600;text-align:center;}
.back-btn{border:none;background:transparent;font-size:16px;position:absolute;left:8px;top:8px;cursor:pointer;}

main{padding-bottom:80px;}

.banner{margin:10px 12px 0;border-radius:12px;overflow:hidden;position:relative;}
.banner img{width:100%;height:140px;object-fit:cover;}
.banner-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.6),transparent);}
.banner-text{position:absolute;left:10px;bottom:10px;color:#fff;}
.banner-text h2{font-size:18px;font-weight:700;}
.banner-text p{font-size:12px;}

.categories{margin:10px 12px 0;}
.categories-title{font-size:14px;font-weight:600;margin-bottom:4px;}
.categories-scroll{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;}
.categories-scroll::-webkit-scrollbar{display:none;}
.cat-pill{flex:0 0 auto;border-radius:999px;border:1px solid #ddd;padding:6px 10px;font-size:12px;background:#fff;cursor:pointer;white-space:nowrap;}
.cat-pill.active{background:#000;color:#fff;border-color:#000;}

.section-title{margin:10px 12px 4px;font-size:16px;font-weight:700;}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:6px 12px 12px;}
.card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);cursor:pointer;}
.card-img{position:relative;width:100%;aspect-ratio:1/1;}
.card-img img{width:100%;height:100%;object-fit:cover;}
.card-badge{position:absolute;left:8px;bottom:8px;background:rgba(0,0,0,0.75);color:#fff;font-size:11px;padding:3px 6px;border-radius:999px;}
.card-body{padding:8px;}
.card-name{font-size:14px;font-weight:600;margin-bottom:2px;}
.card-meta{font-size:11px;color:#666;}

.view{display:none;}
.view.active{display:block;}

.section-header{padding:12px;font-size:14px;}
.section-header h2{font-size:16px;font-weight:700;margin-bottom:4px;}
.section-header p{font-size:12px;color:#666;}

.list{padding:0 12px 80px;}
.list-item{padding:10px 0;border-bottom:1px solid #eee;font-size:13px;display:flex;justify-content:space-between;align-items:center;}
.badge{font-size:11px;padding:3px 8px;border-radius:999px;background:#eee;}
.badge.green{background:#e5f7e5;color:#1a7f1a;}
.badge.blue{background:#e5f0ff;color:#1a3f9f;}

.form{padding:12px;font-size:13px;display:flex;flex-direction:column;gap:6px;}
.form label{font-size:12px;color:#555;}
.form input{padding:8px;border-radius:8px;border:1px solid #ddd;font-size:13px;}
.form button{margin-top:6px;padding:8px;border-radius:999px;border:none;background:#000;color:#fff;font-size:13px;cursor:pointer;}
.info-msg{font-size:12px;margin-top:4px;color:green;}

.bottom-nav{position:fixed;left:50%;transform:translateX(-50%);bottom:52px;width:100%;max-width:480px;background:#fff;border-top:1px solid #eee;display:flex;}
.bottom-nav button{flex:1;border:none;background:#fff;padding:6px 0 4px;font-size:11px;color:#666;display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;}
.bottom-nav button.active{color:#000;font-weight:600;}

.cart-bar{position:fixed;left:50%;transform:translateX(-50%);bottom:0;width:100%;max-width:480px;background:#000;color:#fff;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;font-size:12px;}
.cart-bar button{border:none;background:#fff;color:#000;border-radius:999px;padding:6px 12px;font-size:12px;cursor:pointer;}
#cart-bar-title{font-weight:700;font-size:13px;}
#cart-bar-sub{font-size:11px;color:#ddd;}

.cart-modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,0.4);display:none;align-items:flex-end;justify-content:center;}
.cart-modal{background:#fff;width:100%;max-width:480px;border-radius:16px 16px 0 0;padding:12px;max-height:70vh;overflow-y:auto;font-size:13px;}
.cart-modal h3{font-size:16px;font-weight:700;margin-bottom:8px;}
.cart-item{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #eee;}
.cart-summary{margin-top:8px;display:flex;flex-direction:column;gap:2px;font-size:12px;}
.cart-summary div{display:flex;justify-content:space-between;}
.total-row{font-weight:700;margin-top:4px;}
.resto-row{font-size:11px;color:#555;margin-top:4px;}
.cart-modal button{margin-top:8px;width:100%;padding:8px;border-radius:999px;border:none;font-size:13px;cursor:pointer;}
.cart-modal button.secondary{background:#eee;color:#111;}
.cart-modal button:not(.secondary){background:#000;color:#fff;}

.resto-hero{position:relative;}
.resto-hero img{width:100%;height:180px;object-fit:cover;}
.resto-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.6),transparent);}
.resto-hero-info{position:absolute;left:12px;bottom:10px;color:#fff;}
.resto-hero-info h2{font-size:18px;font-weight:700;}
.resto-hero-info p{font-size:12px;}

.menu-section{padding:10px 12px;}
.menu-section h3{font-size:14px;font-weight:700;margin-bottom:4px;}
.menu-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #eee;}
.menu-item-info{font-size:13px;}
.menu-item-info .name{font-weight:600;}
.menu-item-info .desc{font-size:11px;color:#666;margin-top:2px;}
.menu-item-info .price{font-size:12px;margin-top:2px;}
.menu-item-actions{display:flex;align-items:center;gap:6px;}
.qty-btn{width:24px;height:24px;border-radius:999px;border:1px solid #ddd;background:#fff;font-size:16px;cursor:pointer;}
.qty-value{min-width:16px;text-align:center;font-size:13px;}
